  "nodes": [
    {
      "id": "e100-locked-out",
      "kind": "ending",
      "title": "Locked Out",
      "location": "loc.foyer",
      "thriller": {
        "endingContract": "Caution without leverage leaves Mara outside the truth and outside the room built to contain it."
      },
      "presentation": {
        "background": "bg.foyer"
      },
      "body": [
        {
          "kind": "narration",
          "text": "Mara tests the handle once, then again. The lock does not move, and Elias says nothing that sounds like surprise."
        }
      ],
      "source": {
        "file": "nodes/e100-locked-out.md",
        "format": "markdown-frontmatter"
      },
      "notes": "# Locked Out"
    },
    {
      "id": "e110-curious-ending",
      "kind": "ending",
      "title": "Curious Ending",
      "location": "loc.hallway",
      "thriller": {
        "requiresClues": [
          "clue.host_knows_about_hidden_room"
        ],
        "endingContract": "Pressure applied too early wins an admission, but not access."
      },
      "presentation": {
        "background": "bg.hallway"
      },
      "body": [
        {
          "kind": "dialogue",
          "speaker": "char.host",
          "expression": "calm",
          "text": "If you ask the right question before you have any leverage, Mara, all you learn is how practiced I am at lying to frightened guests."
        }
      ],
      "source": {
        "file": "nodes/e110-curious-ending.md",
        "format": "markdown-frontmatter"
      },
      "notes": "# Curious Ending"
    },
    {
      "id": "e120-silent-ending",
      "kind": "ending",
      "title": "Silent Ending",
      "location": "loc.hallway",
      "thriller": {
        "endingContract": "Restraint preserves the relationship surface, but the house keeps control of the truth."
      },
      "presentation": {
        "background": "bg.hallway"
      },
      "body": [
        {
          "kind": "narration",
          "text": "Mara says nothing. Elias mistakes her silence for patience, and the house keeps one more minute of advantage."
        }
      ],
      "source": {
        "file": "nodes/e120-silent-ending.md",
        "format": "markdown-frontmatter"
      },
      "notes": "# Silent Ending"
    },
