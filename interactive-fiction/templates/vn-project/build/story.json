        {
          "kind": "dialogue",
          "speaker": "char.host",
          "expression": "calm",
          "text": "A house is easiest to misread when the host looks cooperative."
        }
      ],
      "choices": [
        {
          "id": "continue-gallery",
          "text": "Keep following and look for what the hallway records instead of what Elias says.",
